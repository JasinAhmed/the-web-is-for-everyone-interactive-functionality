{% render 'partials/head.liquid', title: nominee.title %}

<header class="site-header">
  <nav class="snelle-links-nav">
    <ul class="snelle-links-lijst pagina-container">
      <li><a href="/#faq">FAQ's</a></li>
      <li><a href="/#over-ons">Over ons</a></li>
      <li><a href="/#contact">Contact</a></li>
    </ul>
  </nav>

  <div class="hoofd-navigatie-balk">
    <nav class="hoofd-navigatie pagina-container">
      <a href="/" class="logo-link">
        <img src="/style/assets/Adconnect.svg" alt="Overlegplatform Ad's" width="180" height="45">
      </a>

      <button class="hamburger" id="hamburger" type="button">☰</button>

      <ul class="hoofd-menu" id="hoofd-menu">
        <li><a class="menu-link" href="/">Home</a></li>
        <li><a class="menu-link" href="/#uitleg">Over Ad's</a></li>
        <li><a class="menu-link" href="/#publicaties">Publicaties</a></li>
        <li><a class="menu-link actief" href="/genomineerden">Talent Award</a></li>
        <li><a class="menu-link" href="/#nieuws">Nieuws</a></li>
        <li class="menu-cta">
          <a href="/#ad-dag" class="knop-cta">Kom naar Ad-dag</a>
        </li>
      </ul>

      <a href="/#ad-dag" class="knop-cta desktop-cta">Kom naar Ad-dag</a>
    </nav>
  </div>
</header>

<main class="pagina-container" id="inhoud">
  <p class="pagina-intro">
    <a class="tekst-link" href="/genomineerden">← Terug naar overzicht</a>
  </p>

  <article class="genomineerde-detail-kaart">
    <figure class="detail-afbeelding">
      {% if nominee.profile_picture %}
        <img src="https://fdnd-agency.directus.app/assets/{{ nominee.profile_picture }}" alt="{{ nominee.title }}" width="500" height="500">
      {% else %}
        <img src="/style/assets/fotothijs.jpg" alt="{{ nominee.title }}" width="500" height="500">
      {% endif %}
    </figure>

    <section class="detail-inhoud">
      <h1>{{ nominee.title }}</h1>

      {% if nominee.institution %}
        <p><strong>Onderwijsinstelling:</strong> {{ nominee.institution }}</p>
      {% endif %}

      {% if nominee.course %}
        <p><strong>Opleiding:</strong> {{ nominee.course }}</p>
      {% endif %}

      {% if nominee.education_variant %}
        <p><strong>Variant:</strong> {{ nominee.education_variant }}</p>
      {% endif %}

      {% if nominee.previous_course %}
        <p><strong>Vorige opleiding:</strong> {{ nominee.previous_course }}</p>
      {% endif %}

      {% if nominee.header %}
        <p><strong>Categorie:</strong> {{ nominee.header }}</p>
      {% endif %}

      {% if nominee.date %}
        <p><strong>Datum:</strong> {{ nominee.date | date: "%d-%m-%Y" }}</p>
      {% endif %}

      {% if nominee.excerpt %}
        <section>
          <h2>Korte introductie</h2>
          <div>{{ nominee.excerpt }}</div>
        </section>
      {% endif %}

      {% if nominee.body %}
        <section>
          <h2>Meer over deze genomineerde</h2>
          <div>{{ nominee.body }}</div>
        </section>
      {% endif %}
    </section>
  </article>

  <section class="reacties-layout">

    <section class="reactie-formulier-sectie">
      <h2>Laat een reactie achter!</h2>

      {% comment %}
        Ik zet novalidate op het formulier, zodat ik mijn eigen error state kan laten zien
        in plaats van de standaard browser melding.
      {% endcomment %}
      <form action="/genomineerden/{{ nominee.id }}" method="POST" class="reactie-formulier" novalidate>
        <label for="naam">Naam:</label>
        <input type="text" id="naam" name="naam">
        <small class="foutmelding" id="naam-fout">Vul je naam in.</small>

        <label for="bericht">Bericht:</label>
        <textarea id="bericht" name="bericht" rows="6"></textarea>
        <small class="foutmelding" id="bericht-fout">Vul eerst een bericht in.</small>

        <button type="submit" class="knop-cta">Verstuur</button>
      </form>
    </section>

    <section class="reacties-sectie">
      <h2>
        {% assign aantal = reacties | size %}
        {% if aantal == 0 %}
          Wees de eerste die reageert!
        {% elsif aantal == 1 %}
          1 reactie
        {% else %}
          {{ aantal }} reacties
        {% endif %}
      </h2>

      {% if reacties and reacties.length > 0 %}
        {% assign gesorteerde_reacties = reacties | sort: "date_created" | reverse %}

        <ul class="reacties-lijst">
          {% for reactie in gesorteerde_reacties %}
            <li class="reactie-kaart" id="reactie-{{ reactie.id }}">
              <article class="reactie-inhoud">
                <header class="reactie-header">
                  <p class="reactie-naam">
                    {% if reactie.name == blank or reactie.name == "test" %}
                      Onbekend
                    {% else %}
                      {{ reactie.name }}
                    {% endif %}
                  </p>

                  {% if reactie.date_created %}
                    <p class="reactie-datum">
                      <time datetime="{{ reactie.date_created }}">
                        {{ reactie.date_created | date: "%d-%m-%Y" }}
                      </time>
                    </p>
                  {% endif %}
                </header>

                <p class="reactie-bericht">{{ reactie.comment }}</p>

                <form action="/reacties/{{ reactie.id }}/verwijderen" method="POST" class="reactie-verwijder-formulier">
                  <input type="hidden" name="nomineeId" value="{{ nominee.id }}">
                  <button type="submit" class="verwijder-knop">Verwijderen</button>
                </form>
              </article>
            </li>
          {% endfor %}
        </ul>
      {% else %}
        <p>Er zijn nog geen reacties geplaatst.</p>
      {% endif %}
    </section>

  </section>

  <footer class="site-footer">
    <section class="footer-blok">
      <h2>Overlegplatform Ad's</h2>
      <p>
        Het Overlegplatform Associate degrees brengt Ad-opleidingen samen
        om kennis te delen en profielen af te stemmen.
      </p>
    </section>

    <section class="footer-blok">
      <h2>Contact</h2>
      <p>
        <a class="footer-link" href="mailto:platformassociatedegrees@outlook.com">
          platformassociatedegrees@outlook.com
        </a>
      </p>
      <p class="footer-klein">
        © Overlegplatform Associate degrees. Alle rechten voorbehouden
      </p>
    </section>
  </footer>
</main>

{% render 'partials/foot.liquid' %}